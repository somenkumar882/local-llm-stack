# Dockerfile.api
FROM python:3.11-slim

WORKDIR /app

# System deps
RUN apt-get update && apt-get install -y \
    build-essential cmake curl git \
    && rm -rf /var/lib/apt/lists/*

# Install llama-cpp-python (CPU by default)
# For CUDA, override: CMAKE_ARGS="-DLLAMA_CUDA=on"
ARG CMAKE_ARGS=""
RUN pip install --no-cache-dir llama-cpp-python ${CMAKE_ARGS:+--global-option="build_ext"}

# Install API deps
COPY api/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# Copy server code
COPY api/server.py .

EXPOSE 8000

CMD ["uvicorn", "server:app", "--host", "0.0.0.0", "--port", "8000", "--workers", "1"]
